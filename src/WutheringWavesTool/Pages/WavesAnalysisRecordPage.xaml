<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Haiyu.Pages.WavesAnalysisRecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="using:Haiyu.Models.Charts"
    xmlns:controls="using:Haiyu.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:itemWrapper="using:Haiyu.Models.Wrapper"
    xmlns:local="using:Haiyu.Pages"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model1="using:Waves.Api.Models.Record"
    mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <i:EventTriggerBehavior EventName="Loaded">
            <i:InvokeCommandAction Command="{x:Bind ViewModel.LoadedCommand}" />
        </i:EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <!--  用x:Load控制显示  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <controls:TitleBar
            x:Name="titleBar"
            IsExtendsContentIntoTitleBar="True"
            TitleMode="Tall">
            <controls:TitleBar.Header>
                <MenuBar>
                    <MenuBarItem Title="导入">
                        <MenuFlyoutItem Text="Haiyu旧版数据" />
                    </MenuBarItem>
                    <MenuBarItem Title="数据">
                        <MenuFlyoutItem Text="导出数据" />
                        <MenuFlyoutItem Text="导出为图片（实验性）" />
                    </MenuBarItem>
                </MenuBar>
            </controls:TitleBar.Header>
        </controls:TitleBar>
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <ScrollView>
                <StackPanel HorizontalAlignment="Stretch">
                    <Border
                        Padding="14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <ComboBox ItemsSource="{x:Bind ViewModel.NavItems, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectNavItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="model1:GameRecordNavigationItem">
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Run Text="平均出货" />
                                <Run Text="{x:Bind ViewModel.StarAvgValue, Mode=OneWay}" />
                                <Run Text="抽" />
                            </TextBlock>
                            <ScrollViewer
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.StarItems, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="itemWrapper:RecordActivityFiveStarItemWrapper">
                                            <Grid
                                                Margin="0,8,0,0"
                                                Padding="10"
                                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                BorderBrush="{ThemeResource SolidBackgroundFillColorBaseAltBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="auto" />
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <Border
                                                    Grid.RowSpan="2"
                                                    Width="40"
                                                    Height="40"
                                                    Padding="5"
                                                    Background="#292A23"
                                                    CornerRadius="5">
                                                    <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="5,0,0,0"
                                                    Text="{x:Bind Name}" />
                                                <Grid
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="5,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition />
                                                        <ColumnDefinition Width="auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar
                                                        MinHeight="15"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Foreground="{x:Bind Count, Converter={StaticResource RecordColorConverter}}"
                                                        Maximum="80"
                                                        Style="{ThemeResource FillHeightProgressBar}"
                                                        Value="{x:Bind Count}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="0,0,5,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Text="{x:Bind Count}" />
                                                </Grid>
                                                <Border
                                                    Grid.RowSpan="2"
                                                    Grid.Column="2"
                                                    Margin="15,10,0,0"
                                                    Padding="10,6"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{ThemeResource AccentAAFillColorDefaultBrush}"
                                                    CornerRadius="5"
                                                    Visibility="{x:Bind Flage, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock
                                                        Margin="0,-5,0,0"
                                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                        Text="{x:Bind Flage, Converter={StaticResource RecordStarConverter}}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollView>
            <Grid
                Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                BorderThickness="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Text="{x:Bind ViewModel.GuaranteeHeader, Mode=OneWay}" TextAlignment="Left" />
                <ComboBox
                    HorizontalAlignment="Right"
                    ItemsSource="{x:Bind ViewModel.GuaranteItems, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectGuarante, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="model1:GuaranteRangeWrapper">
                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <lvc:PieChart Grid.Row="1" SeriesSource="{x:Bind ViewModel.GuaranteeChart, Mode=OneWay}">
                    <lvc:PieChart.SeriesTemplate>
                        <DataTemplate x:DataType="cm:PipeData">
                            <lvc:XamlPieSeries
                                MaxRadialColumnWidth="60"
                                SeriesName="{x:Bind Name, Mode=OneWay}"
                                Values="{x:Bind Values, Mode=OneWay}" />
                        </DataTemplate>
                    </lvc:PieChart.SeriesTemplate>
                </lvc:PieChart>
            </Grid>
        </Grid>
    </Grid>
</Page>
