<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Haiyu.Pages.GamePages.WavesCloudGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:Waves.Api.Models.CloudGame"
    xmlns:cloud="using:Waves.Core.Models.CloudGame"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:Haiyu.Pages.GamePages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:Haiyu.Controls"
    mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <i:EventTriggerBehavior>
            <i:InvokeCommandAction Command="{x:Bind ViewModel.LoadedCommand}" />
        </i:EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <Grid>
        <ProgressBar
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Background="Transparent"
            IsIndeterminate="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" />

        <Border
            Width="380"
            Margin="12"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid Padding="16" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="余额概况" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Width="35"
                        Height="35"
                        Padding="4"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.RefreshCardCommand}"
                        Style="{ThemeResource TransparentButtonStyle}">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="15"
                            Glyph="&#xE72C;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        ItemsSource="{x:Bind ViewModel.Logins, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectLogin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="cloud:CloudGameLoginSession">
                                <TextBlock FontFamily="{ThemeResource DefaultFont}" Text="{x:Bind OrginData.Phone}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button
                        Grid.Column="1"
                        Width="35"
                        Height="35"
                        Padding="4"
                        Command="{x:Bind ViewModel.AddUserCommand}"
                        Style="{ThemeResource TransparentButtonStyle}"
                        ToolTipService.ToolTip="创建账号">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="15"
                            Glyph="&#xE8FA;" />
                    </Button>
                </Grid>

                <Grid
                    Grid.Row="2"
                    ColumnSpacing="5"
                    RowSpacing="5">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="22"
                                Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                Glyph="&#xE8D4;" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.WallData.FreeString, Mode=OneWay}" />
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="免费额度" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="22"
                                Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                Glyph="&#xE8C7;" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.WallData.PlayerCardString, Mode=OneWay}" />
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="畅享卡" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="22"
                                Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                Glyph="&#xE7FC;" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="1"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.WallData.PayString, Mode=OneWay}" />
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="付费时间" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="22"
                                Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                Glyph="&#xEC92;" />
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.WallData.ExperienseTimeString, Mode=OneWay}" />
                                <TextBlock
                                    FontFamily="{ThemeResource DefaultFont}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="体验卡时间" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <Grid
            Grid.Row="1"
            Width="220"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            CornerRadius="5">

            <Grid Grid.Column="1" Padding="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid
                    Margin="15,0,15,-2"
                    BorderBrush="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                    BorderThickness="1,1,1,0"
                    CornerRadius="5 5 0 0">
                    <SystemBackdropElement Grid.ColumnSpan="2" CornerRadius="5 5 0 0">
                        <SystemBackdropElement.SystemBackdrop>
                            <DesktopAcrylicBackdrop />
                        </SystemBackdropElement.SystemBackdrop>
                    </SystemBackdropElement>
                    <TextBlock
                        Margin="4"
                        HorizontalAlignment="Center"
                        FontFamily="{ThemeResource DefaultFont}"
                        Text="{x:Bind ViewModel.BottomText, Mode=OneWay}" />
                </Grid>
                <Grid
                    Grid.Row="1"
                    BorderBrush="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <SystemBackdropElement Grid.ColumnSpan="2" CornerRadius="5">
                        <SystemBackdropElement.SystemBackdrop>
                            <DesktopAcrylicBackdrop />
                        </SystemBackdropElement.SystemBackdrop>
                    </SystemBackdropElement>
                    <Button
                        Grid.Row="1"
                        Height="60"
                        Margin="5,5,0,5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource SystemFillColorSuccess}"
                        BorderThickness="0"
                        Command="{x:Bind ViewModel.InvokeTaskCommand}"
                        CornerRadius="4"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="20"
                                Glyph="&#xE7FC;" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource DefaultFont}"
                                FontSize="15"
                                Text="{x:Bind ViewModel.StartGameText, Mode=OneWay}" />
                        </Grid>

                    </Button>
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        Width="60"
                        Margin="5,5,5,5"
                        BorderThickness="0"
                        Style="{ThemeResource TransparentButtonStyle}">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="18"
                            Glyph="&#xEC7A;" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Command="{x:Bind ViewModel.OpenSettingsDialogCommand}" Text="设置">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF8B0;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
        <Grid
            Margin="0,10,10,10"
            HorizontalAlignment="Right"
            VerticalAlignment="Top">
            <SystemBackdropElement CornerRadius="5">
                <SystemBackdropElement.SystemBackdrop>
                    <DesktopAcrylicBackdrop />
                </SystemBackdropElement.SystemBackdrop>
            </SystemBackdropElement>
            <StackPanel Orientation="Horizontal">
                <Button Command="{x:Bind ViewModel.ShowWavesAnalysisCommand}" Style="{ThemeResource TransparentButtonStyle}">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="15"
                        Glyph="&#xF133;" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
