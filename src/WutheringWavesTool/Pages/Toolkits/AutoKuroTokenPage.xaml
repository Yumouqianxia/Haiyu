<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Haiyu.Pages.Toolkits.AutoKuroTokenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adb="using:ChromeCDPSharp.Common"
    xmlns:controls="using:Haiyu.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Haiyu.Pages.Toolkits"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.Resources>
            <Style x:Key="TokenPanelBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="14" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="5" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <controls:TitleBar
            x:Name="titleBar"
            Title="库街区 Token 读取"
            IsExtendsContentIntoTitleBar="True" />

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <InfoBar
                    Title="准备工作"
                    IsClosable="False"
                    IsOpen="True"
                    Message="请先在安卓设备上开启 USB 调试，并连接到PC上，并根据提示允许本机进行USB调试，随后打开库街区的数据面板页面"
                    Severity="Informational" />

                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE8B7;" />
                            <Grid Grid.Column="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="ADB 路径" />
                                <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        IsReadOnly="True"
                                        PlaceholderText="请选择 adb.exe"
                                        Text="{x:Bind ViewModel.AdbPath, Mode=OneWay}" />
                                    <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectAdbPathCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                FontFamily="Segoe Fluent Icons"
                                                FontSize="14"
                                                Glyph="&#xE838;" />
                                            <TextBlock Text="浏览" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE968;" />
                            <Grid Grid.Column="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="调试端口" />
                                <NumberBox
                                    Grid.Row="1"
                                    Maximum="65535"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{x:Bind ViewModel.Port, Mode=TwoWay}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE772;" />
                            <Grid Grid.Column="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="安卓设备" />
                                <TextBlock
                                    Grid.Row="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                                <ComboBox
                                    Grid.Row="2"
                                    MinWidth="320"
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                                    PlaceholderText="暂无设备"
                                    SelectedItem="{x:Bind ViewModel.SelectDevice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="adb:AdbDeviceInfo">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Serial}" />
                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Model}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind State}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid
                        Grid.Column="1"
                        ColumnSpacing="8"
                        RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Button
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Command="{x:Bind ViewModel.RefreshDeviceCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE72C;" />
                                <TextBlock Text="刷新设备" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Command="{x:Bind ViewModel.AutoConnectCommand}"
                            Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE8CE;" />
                                <TextBlock Text="连接" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Command="{x:Bind ViewModel.ManualReconnectCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE777;" />
                                <TextBlock Text="手动重连" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Command="{x:Bind ViewModel.StartTrafficMonitorCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE9D9;" />
                                <TextBlock Text="监控流量" />
                            </StackPanel>
                        </Button>

                    </Grid>
                </Grid>

                <Grid Grid.Row="3" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE950;" />
                            <Grid Grid.Column="1" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="连接状态" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="浏览器调试连接与 CDP 客户端状态。"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Grid Grid.Row="1" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="4">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="WebSocket" />
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.WebSocketState, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CDP" />
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.CdpState, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE9D9;" />
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="过滤结果" />

                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Command="{x:Bind ViewModel.CopySessionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="12"
                                        Glyph="&#xE8C8;" />
                                    <TextBlock FontSize="12" Text="复制" />
                                </StackPanel>
                            </Button>
                            <Grid
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,5,0,0"
                                RowSpacing="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource SystemChromeGrayColor}"
                                        Text="Did:" />
                                    <TextBlock Text="{x:Bind ViewModel.Did, Mode=OneWay}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource SystemChromeGrayColor}"
                                        Text="Token:" />
                                    <TextBlock
                                        MaxWidth="300"
                                        Text="{x:Bind ViewModel.Token, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="2"
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource SystemChromeGrayColor}"
                                        Text="PlayerId:" />
                                    <TextBlock Text="{x:Bind ViewModel.PlayerId, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="3"
                    ColumnSpacing="12"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE968;" />
                            <Grid Grid.Column="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="WebSocket" />
                                <TextBlock
                                    Grid.Row="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="浏览器调试连接的底层状态。"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="2"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.WebSocketState, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource TokenPanelBorderStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE950;" />
                            <Grid Grid.Column="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="CDP" />
                                <TextBlock
                                    Grid.Row="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Chrome DevTools Protocol 客户端状态。"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="2"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.CdpState, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <TextBox
                    Grid.Row="4"
                    IsReadOnly="True"
                    PlaceholderText="日志"
                    Text="{x:Bind ViewModel.LogText, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </Grid>
        </ScrollView>
    </Grid>
</Page>
