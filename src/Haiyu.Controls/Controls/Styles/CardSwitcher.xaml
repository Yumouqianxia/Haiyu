<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Haiyu.Controls">
    <Style x:Key="DefaultCardsSwitcher" TargetType="local:CardSwitcher">
        <Setter Target="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:CardSwitcher">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <ContentControl
                            x:Name="CardBack"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Content="{TemplateBinding Card1}"
                            Opacity="1"
                            RenderTransformOrigin="0.5,0.5" />
                        <ContentControl
                            x:Name="CardFront"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Content="{TemplateBinding Card2}"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
