<Page
    x:Class="Haiyu.Pages.GameWikis.WavesWikiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:item="using:Waves.Api.Models.Communitys"
    xmlns:local="using:Haiyu.Pages.GameWikis"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:source="using:Waves.Api.Models.Communitys.DataCenter"
    xmlns:ui="using:Haiyu.Controls"
    xmlns:ui1="using:CommunityToolkit.WinUI"
    xmlns:wiki="using:Waves.Api.Models.GameWikiiClient"
    xmlns:wikiModel="using:Haiyu.Models.Wrapper.Wiki"
    xmlns:wrapper="using:Haiyu.Models.Wrapper"
    xmlns:wuc="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <i:EventTriggerBehavior EventName="Loaded">
            <i:InvokeCommandAction Command="{x:Bind ViewModel.LoadedCommand}" />
        </i:EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <Page.Resources>
        <media:AttachedCardShadow
            x:Key="CommonShadow"
            BlurRadius="10"
            Opacity="1"
            Offset="4"
            Color="Black" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="185" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Visibility="{x:Bind ViewModel.Loading, Mode=OneWay, Converter={StaticResource BoolToVisibilityReversalConverter}}">
            <Grid.ChildrenTransitions>
                <TransitionCollection>
                    <RepositionThemeTransition />
                </TransitionCollection>
            </Grid.ChildrenTransitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <StackPanel HorizontalAlignment="Stretch" Orientation="Vertical">
                <TextBlock
                    Margin="5,0,0,0"
                    FontFamily="{ThemeResource DefaultFont}"
                    FontSize="20"
                    Text="当前活动" />
                <ScrollViewer
                    Padding="0,0,0,10"
                    VerticalAlignment="Top"
                    HorizontalScrollBarVisibility="Visible"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollMode="Disabled">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Actives, Mode=OneWay}">
                        <ItemsControl.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                            </TransitionCollection>
                        </ItemsControl.ItemContainerTransitions>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="wikiModel:HotContentSideWrapper">
                                <ui:HeaderTileCard
                                    Width="350"
                                    Margin="3"
                                    Command="{x:Bind JumpWebCommand}"
                                    CornerRadius="5">
                                    <Grid Padding="5" BorderThickness="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>
                                        <ui:ImageEx
                                            Width="120"
                                            Height="120"
                                            CornerRadius="5"
                                            Source="{x:Bind ImageUrl}"
                                            Stretch="Uniform" />
                                        <Grid Grid.Column="1" Margin="8,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <TextBlock
                                                FontFamily="{ThemeResource DefaultFont}"
                                                FontSize="17"
                                                Text="{x:Bind Title}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Margin="0,10,0,0"
                                                FontSize="15"
                                                Text="{x:Bind StartTime}"
                                                Visibility="{x:Bind TimeVisibility}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                Margin="0,10,0,0"
                                                FontSize="15"
                                                Text="{x:Bind EndTime}"
                                                Visibility="{x:Bind TimeVisibility}" />
                                            <StackPanel
                                                Grid.Row="3"
                                                VerticalAlignment="Bottom"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,3,0,0"
                                                    FontFamily="Segoe Fluent Icons"
                                                    Text="&#xEC92;" />
                                                <TextBlock
                                                    Margin="3,0,0,0"
                                                    Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                                    Text="{x:Bind Message, Mode=OneWay}" />
                                                <TextBlock Text="" />
                                                <TextBlock Text="{x:Bind TotalSpan}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                        <ProgressBar
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Margin="0,5,0,0"
                                            HorizontalAlignment="Stretch"
                                            Maximum="{x:Bind MaxProgress, Mode=OneWay}"
                                            Value="{x:Bind CurrentProgress, Mode=OneWay}" />
                                    </Grid>
                                </ui:HeaderTileCard>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>
        <Border Grid.Row="1" Visibility="{x:Bind ViewModel.Loading, Mode=OneWay, Converter={StaticResource BoolToVisibilityReversalConverter}}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>
                <Grid
                    Margin="5"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SystemColorGrayTextBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="{x:Bind ViewModel.KuroLogin, Mode=OneWay, Converter={StaticResource BoolToVisibilityReversalConverter}}">
                    <SystemBackdropElement>
                        <SystemBackdropElement.SystemBackdrop>
                            <DesktopAcrylicBackdrop />
                        </SystemBackdropElement.SystemBackdrop>
                    </SystemBackdropElement>
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="18"
                            Text="未登录或登陆过期" />
                    </StackPanel>
                </Grid>
                <Grid
                    Margin="5"
                    CornerRadius="4"
                    Visibility="{x:Bind ViewModel.KuroLogin, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Command="{x:Bind ViewModel.RefreshUserCommand}" Text="刷新账号数据缓存">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Grid.ContextFlyout>
                    <Grid
                        Margin="0,0,1.5,0"
                        BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <SystemBackdropElement Grid.RowSpan="4" CornerRadius="5">
                            <SystemBackdropElement.SystemBackdrop>
                                <DesktopAcrylicBackdrop />
                            </SystemBackdropElement.SystemBackdrop>
                        </SystemBackdropElement>
                        <ListView
                            Padding="4"
                            ItemsSource="{x:Bind ViewModel.Gamers, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectGamer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="item:GameRoilDataItem">
                                    <StackPanel Padding="0,10" Orientation="Horizontal">
                                        <ui:ImageEx
                                            Width="30"
                                            Height="30"
                                            Source="{x:Bind HeadPhotoUrl, Mode=OneWay}" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="18"
                                            Text="{x:Bind RoleName, Mode=OneWay}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemColorGrayTextBrush}"
                                            Text="-" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemColorGrayTextBrush}"
                                            Text="{x:Bind ServerName, Mode=OneWay}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Border
                            Grid.Row="1"
                            Height="1"
                            Margin="20,0"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel
                            Grid.Row="2"
                            Margin="0,5,0,0"
                            Padding="5"
                            HorizontalAlignment="Center"
                            CornerRadius="4"
                            Orientation="Horizontal">
                            <Button Command="{x:Bind ViewModel.OpenDataCenterCommand}" Content="数据面板" />
                            <Button
                                Margin="5,0,0,0"
                                Command="{x:Bind ViewModel.OpenResourceBriefingCommand}"
                                Content="资源简报" />
                            <Button
                                Margin="5,0,0,0"
                                Command="{x:Bind ViewModel.OpenGrowthCalculatorCommand}"
                                Content="养成计算器" />
                            <Button
                                Margin="5,0,0,0"
                                Command="{x:Bind ViewModel.OpenGameSignCommand}"
                                Content="游戏签到" />
                        </StackPanel>
                    </Grid>
                    <Grid
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <SystemBackdropElement CornerRadius="5">

                            <SystemBackdropElement.SystemBackdrop>
                                <DesktopAcrylicBackdrop />
                            </SystemBackdropElement.SystemBackdrop>
                        </SystemBackdropElement>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="18"
                            Text="敬请期待" />
                    </Grid>

                </Grid>
                <Grid
                    Grid.Column="1"
                    Margin="0,5,5,5"
                    CornerRadius="3">
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>
                    <Grid CornerRadius="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="100" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="1" Margin="0,4,0,0">
                            <SystemBackdropElement Grid.RowSpan="4" CornerRadius="5">
                                <SystemBackdropElement.SystemBackdrop>
                                    <DesktopAcrylicBackdrop />
                                </SystemBackdropElement.SystemBackdrop>
                            </SystemBackdropElement>
                            <FlipView Background="Transparent" ItemsSource="{x:Bind ViewModel.RoleActive, Mode=OneWay}">
                                <FlipView.ItemTemplate>
                                    <DataTemplate x:DataType="wikiModel:EventContentSideWrapper">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <StackPanel Background="{ThemeResource SystemControlPageBackgroundAltMediumBrush}">
                                                <TextBlock Margin="5" FontSize="14">
                                                    <Run FontWeight="Bold" Text="{x:Bind Title}" />
                                                    <Run Foreground="{ThemeResource AccentAAFillColorDefaultBrush}" Text="{x:Bind DisplayTime}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <ProgressBar
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                Background="Transparent"
                                                Maximum="{x:Bind MaxProgress, Mode=OneWay}"
                                                Value="{x:Bind CurrentProgress, Mode=OneWay}" />
                                            <Grid
                                                Grid.Row="2"
                                                Margin="0,3,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:ImageEx
                                                    Grid.Row="1"
                                                    Source="{x:Bind Image1}"
                                                    Stretch="Uniform" />
                                                <Grid Grid.Row="1" Grid.Column="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition />
                                                        <RowDefinition />
                                                        <RowDefinition />
                                                    </Grid.RowDefinitions>
                                                    <ui:ImageEx Grid.Row="0" Source="{x:Bind Image2}" />
                                                    <ui:ImageEx Grid.Row="1" Source="{x:Bind Image3}" />
                                                    <ui:ImageEx Grid.Row="2" Source="{x:Bind Image4}" />
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </FlipView.ItemTemplate>
                            </FlipView>
                        </Grid>
                        <Grid Grid.Row="0" VerticalAlignment="Top">
                            <SystemBackdropElement Grid.RowSpan="4" CornerRadius="5">
                                <SystemBackdropElement.SystemBackdrop>
                                    <DesktopAcrylicBackdrop />
                                </SystemBackdropElement.SystemBackdrop>
                            </SystemBackdropElement>
                            <FlipView Background="Transparent" ItemsSource="{x:Bind ViewModel.WeaponActive, Mode=OneWay}">
                                <FlipView.ItemTemplate>
                                    <DataTemplate x:DataType="wikiModel:EventContentSideWrapper">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Background="{ThemeResource SystemControlPageBackgroundAltMediumBrush}">
                                                <TextBlock Margin="5" FontSize="14">
                                                    <Run FontWeight="Bold" Text="{x:Bind Title}" />
                                                    <Run Foreground="{ThemeResource AccentAAFillColorDefaultBrush}" Text="{x:Bind DisplayTime}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <ProgressBar
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                Background="Transparent"
                                                Maximum="{x:Bind MaxProgress}"
                                                Value="{x:Bind CurrentProgress}" />
                                            <Grid
                                                Grid.Row="2"
                                                Margin="0,3,0,0"
                                                Padding="5"
                                                HorizontalAlignment="Center">
                                                <Grid Grid.Row="1" Grid.Column="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="auto" />
                                                        <ColumnDefinition Width="auto" />
                                                        <ColumnDefinition Width="auto" />
                                                        <ColumnDefinition Width="auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:ImageEx
                                                        Grid.Column="0"
                                                        Width="50"
                                                        Height="50"
                                                        Source="{x:Bind Image1}" />
                                                    <ui:ImageEx
                                                        Grid.Column="1"
                                                        Width="50"
                                                        Height="50"
                                                        Source="{x:Bind Image2}" />
                                                    <ui:ImageEx
                                                        Grid.Column="2"
                                                        Width="50"
                                                        Height="50"
                                                        Source="{x:Bind Image3}" />
                                                    <ui:ImageEx
                                                        Grid.Column="3"
                                                        Width="50"
                                                        Height="50"
                                                        Source="{x:Bind Image4}" />
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </FlipView.ItemTemplate>
                            </FlipView>
                        </Grid>
                    </Grid>

                </Grid>
            </Grid>
        </Border>
        <ui:Shimmer
            Margin="0,10,0,0"
            Style="{ThemeResource DefaultShimmerStyle}"
            Visibility="{x:Bind ViewModel.Loading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        <ui:Shimmer
            Grid.Row="1"
            Margin="0,10,0,0"
            Style="{ThemeResource DefaultShimmerStyle}"
            Visibility="{x:Bind ViewModel.Loading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</Page>
