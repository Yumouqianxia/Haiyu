                                        FontSize="14"
                                        Text="{x:Bind ViewModel.Base.WeeklyInstCount, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource DefaultFont}"
                                        FontSize="14"
                                        Text="{x:Bind ViewModel.Base.RoleNum, Mode=OneWay}" />
