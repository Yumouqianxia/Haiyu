<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Haiyu.Pages.WavesAnalysisRecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="using:Haiyu.Models.Charts"
    xmlns:controls="using:Haiyu.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:itemWrapper="using:Haiyu.Models.Wrapper"
    xmlns:local="using:Haiyu.Pages"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model1="using:Waves.Api.Models.Record"
    mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <i:EventTriggerBehavior EventName="Loaded">
            <i:InvokeCommandAction Command="{x:Bind ViewModel.LoadedCommand}" />
        </i:EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <Grid>
        <Grid
            Width="200"
            Height="200"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <!--    -->
            <ProgressRing
                Width="40"
                Height="40"
                IsActive="True" />
            <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                FontSize="18"
                Text="刷新数据" />
        </Grid>
        <Grid Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityReversalConverter}}">
            <!--    -->
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <controls:TitleBar
                x:Name="titleBar"
                IsExtendsContentIntoTitleBar="True"
                TitleMode="Tall">
                <controls:TitleBar.Header>
                    <MenuBar>
                        <MenuBarItem Title="导入">
                            <MenuFlyoutItem Command="{x:Bind ViewModel.ImportDefaultFolderCommand}" Text="旧版数据(默认)" />
                            <MenuFlyoutItem Command="{x:Bind ViewModel.ImportFolderCommand}" Text="旧版数据(自定义文件夹)" />
                        </MenuBarItem>
                        <MenuBarItem Title="数据">
                            <MenuFlyoutItem Text="导出数据" />
                            <MenuFlyoutItem Text="导出为图片（实验性）" />
                        </MenuBarItem>
                    </MenuBar>
                </controls:TitleBar.Header>
            </controls:TitleBar>
            <Grid
                Grid.Row="1"
                Margin="5"
                ColumnSpacing="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <ScrollView>
                    <Border
                        Padding="14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <ComboBox ItemsSource="{x:Bind ViewModel.NavItems, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectNavItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="model1:GameRecordNavigationItem">
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Run Text="平均出货" />
                                <Run Text="{x:Bind ViewModel.StarAvgValue, Mode=OneWay}" />
                                <Run Text="抽" />
                            </TextBlock>
                            <ScrollViewer
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.StarItems, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="itemWrapper:RecordActivityFiveStarItemWrapper">
                                            <Grid
                                                Margin="0,8,0,0"
                                                Padding="10"
                                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                BorderBrush="{ThemeResource SolidBackgroundFillColorBaseAltBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="auto" />
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <Border
                                                    Grid.RowSpan="2"
                                                    Width="40"
                                                    Height="40"
                                                    Padding="5"
                                                    Background="#292A23"
                                                    CornerRadius="5">
                                                    <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="5,0,0,0"
                                                    Text="{x:Bind Name}" />
                                                <Grid
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="5,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition />
                                                        <ColumnDefinition Width="auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar
                                                        MinHeight="15"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Foreground="{x:Bind Count, Converter={StaticResource RecordColorConverter}}"
                                                        Maximum="80"
                                                        Style="{ThemeResource FillHeightProgressBar}"
                                                        Value="{x:Bind Count}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="0,0,5,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Text="{x:Bind Count}" />
                                                </Grid>
                                                <Border
                                                    Grid.RowSpan="2"
                                                    Grid.Column="2"
                                                    Margin="15,10,0,0"
                                                    Padding="10,6"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{ThemeResource AccentAAFillColorDefaultBrush}"
                                                    CornerRadius="5"
                                                    Visibility="{x:Bind Flage, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock
                                                        Margin="0,-5,0,0"
                                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                        Text="{x:Bind Flage, Converter={StaticResource RecordStarConverter}}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </ScrollView>
                <Grid
                    Grid.Column="1"
                    ColumnSpacing="5"
                    RowSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120" />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid
                        Grid.ColumnSpan="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="抽卡总数" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.Header.AllTotal, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="称号" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.Header.Designation, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="双金次数" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.Header.DoubleCount, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="歪的次数" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.Header.CrookedTotal, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="综合评分" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.Header.Score, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="平均出金" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.Header.AvgPulls, Mode=OneWay}" />
                                <Run Text="抽" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel
                            Grid.Column="6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="出金率" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.Header.ActualFiveStarRate, Mode=OneWay}" />
                                <Run Text="%" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel
                            Grid.Column="7"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="记录天数" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.Header.Days, Mode=OneWay}" />
                                <Run Text="天" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <Grid
                        Grid.Row="1"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.GuaranteeHeader, Mode=OneWay}"
                            TextAlignment="Left" />
                        <ComboBox
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ItemsSource="{x:Bind ViewModel.GuaranteItems, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectGuarante, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="model1:GuaranteRangeWrapper">
                                    <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <lvc:PieChart
                            Grid.Row="1"
                            Background="Transparent"
                            SeriesSource="{x:Bind ViewModel.GuaranteeChart, Mode=OneWay}">
                            <lvc:PieChart.SeriesTemplate>
                                <DataTemplate x:DataType="cm:PipeData">
                                    <lvc:XamlPieSeries
                                        MaxRadialColumnWidth="60"
                                        SeriesName="{x:Bind Name, Mode=OneWay}"
                                        Values="{x:Bind Values, Mode=OneWay}" />
                                </DataTemplate>
                            </lvc:PieChart.SeriesTemplate>
                        </lvc:PieChart>
                    </Grid>
                    <Grid
                        Grid.Row="1"
                        Grid.Column="1"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock
                            HorizontalAlignment="Center"
                            Text="出货占比"
                            TextAlignment="Left" />
                        <lvc:PieChart
                            Grid.Row="1"
                            Background="Transparent"
                            SeriesSource="{x:Bind ViewModel.StarRatioChart, Mode=OneWay}">
                            <lvc:PieChart.SeriesTemplate>
                                <DataTemplate x:DataType="cm:PipeData">
                                    <lvc:XamlPieSeries
                                        MaxRadialColumnWidth="60"
                                        SeriesName="{x:Bind Name, Mode=OneWay}"
                                        Values="{x:Bind Values, Mode=OneWay}" />
                                </DataTemplate>
                            </lvc:PieChart.SeriesTemplate>
                        </lvc:PieChart>
                    </Grid>
                    <Grid
                        Grid.Row="1"
                        Grid.Column="2"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Text="各卡池抽数" TextAlignment="Left" />
                        <lvc:PieChart
                            Grid.Row="1"
                            Background="Transparent"
                            SeriesSource="{x:Bind ViewModel.PoolChart, Mode=OneWay}">
                            <lvc:PieChart.SeriesTemplate>
                                <DataTemplate x:DataType="cm:PipeData">
                                    <lvc:XamlPieSeries
                                        MaxRadialColumnWidth="60"
                                        SeriesName="{x:Bind Name, Mode=OneWay}"
                                        Values="{x:Bind Values, Mode=OneWay}" />
                                </DataTemplate>
                            </lvc:PieChart.SeriesTemplate>
                        </lvc:PieChart>
                    </Grid>
                    <Grid
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentAAFillColorDisabled}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Text="每日抽数" TextAlignment="Left" />
                        <lvc:CartesianChart
                            Grid.Row="1"
                            AutoUpdateEnabled="True"
                            Background="Transparent"
                            ZoomMode="Both">
                            <lvc:CartesianChart.Series>
                                <lvc:SeriesCollection>
                                    <lvc:XamlColumnSeries Values="{x:Bind ViewModel.TimeLineChart, Mode=OneWay}" />
                                </lvc:SeriesCollection>
                            </lvc:CartesianChart.Series>
                            <lvc:CartesianChart.XAxes>
                                <lvc:AxesCollection>
                                    <lvc:XamlDateTimeAxis DateFormatter="{x:Bind ViewModel.Formatter}" />
                                </lvc:AxesCollection>
                            </lvc:CartesianChart.XAxes>
                            <lvc:CartesianChart.YAxes>
                                <lvc:AxesCollection>
                                    <lvc:XamlAxis TextSize="10" />
                                </lvc:AxesCollection>
                            </lvc:CartesianChart.YAxes>
                        </lvc:CartesianChart>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
