<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Haiyu.Pages.Dialogs.UpdateAppDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Haiyu.Pages.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    CornerRadius="5"
    mc:Ignorable="d">

    <Grid Width="360" Height="150">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical">

            <TextBlock
                FontFamily="{ThemeResource DefaultFont}"
                FontSize="18"
                Text="应用程序有更新" />
            <TextBlock Margin="0,10,0,0" Foreground="{ThemeResource SystemColorGrayTextBrush}">
                <Run Text="新版本：" />
                <Run Text="{x:Bind ViewModel.Version, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Margin="0,10,0,0" Foreground="{ThemeResource SystemColorGrayTextBrush}">
                <Run Text="下载大小：" />
                <Run Text="{x:Bind ViewModel.Size, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>
        <ProgressBar
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Maximum="100"
            Value="{x:Bind ViewModel.Progress, Mode=OneWay}" />
        <Grid Grid.Row="2" ColumnSpacing="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.DownloadAppUpdateCommand}"
                Content="下载更新并安装" />
            <Button
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.SkipAppUpdateCommand}"
                Content="跳过此版本"
                Visibility="{x:Bind ViewModel.SkipVisiblity, Mode=OneWay}" />
            <Button
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CloseCommand}"
                Content="取消" />
        </Grid>
    </Grid>
</ContentDialog>
