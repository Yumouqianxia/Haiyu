<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Haiyu.Pages.GamePages.WavesV2GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ani="using:CommunityToolkit.WinUI.Animations"
    xmlns:b="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:bs="using:Haiyu.Behaviors"
    xmlns:control="using:Haiyu.Controls"
    xmlns:convert="using:Haiyu.Converter.DownloadState"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:item="using:Waves.Core.Models"
    xmlns:launcheModel="using:Waves.Api.Models"
    xmlns:local="using:Haiyu.Pages.GamePages"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:m="using:Haiyu.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:n="using:System.Numerics"
    xmlns:property="using:Haiyu.Controls.Propertys"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:wui="using:CommunityToolkit.WinUI.Controls"
    Background="Transparent"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <i:EventTriggerBehavior EventName="Loaded">
            <i:InvokeCommandAction Command="{x:Bind ViewModel.LoadedCommand}" />
        </i:EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <Page.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="WavesCommandSurfaceBrush" Color="#1FFFFFFF" />
                <SolidColorBrush x:Key="WavesCommandBorderBrush" Color="#52FFFFFF" />
                <SolidColorBrush x:Key="WavesPrimaryActionBrush" Color="#FF173A44" />
                <SolidColorBrush x:Key="WavesPrimaryActionPointerOverBrush" Color="#FF204D59" />
                <SolidColorBrush x:Key="WavesPrimaryActionPressedBrush" Color="#FF0E2C35" />
                <SolidColorBrush x:Key="WavesPrimaryActionForegroundBrush" Color="#FFFFFFFF" />
                <SolidColorBrush x:Key="WavesSecondaryActionBrush" Color="#33FFFFFF" />
                <SolidColorBrush x:Key="WavesSecondaryActionPointerOverBrush" Color="#59FFFFFF" />
                <SolidColorBrush x:Key="WavesSecondaryActionPressedBrush" Color="#73FFFFFF" />
                <SolidColorBrush x:Key="WavesStatusAccentBrush" Color="#FF177D8D" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="WavesCommandSurfaceBrush" Color="#E61A1E22" />
                <SolidColorBrush x:Key="WavesCommandBorderBrush" Color="#38FFFFFF" />
                <SolidColorBrush x:Key="WavesPrimaryActionBrush" Color="#FFE0F5F7" />
                <SolidColorBrush x:Key="WavesPrimaryActionPointerOverBrush" Color="#FFFFFFFF" />
                <SolidColorBrush x:Key="WavesPrimaryActionPressedBrush" Color="#FFC2E2E7" />
                <SolidColorBrush x:Key="WavesPrimaryActionForegroundBrush" Color="#FF0A242B" />
                <SolidColorBrush x:Key="WavesSecondaryActionBrush" Color="#8A253038" />
                <SolidColorBrush x:Key="WavesSecondaryActionPointerOverBrush" Color="#BF33434C" />
                <SolidColorBrush x:Key="WavesSecondaryActionPressedBrush" Color="#E6172025" />
                <SolidColorBrush x:Key="WavesStatusAccentBrush" Color="#FF79D9E5" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>
        <Style x:Key="WavesPrimaryLaunchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource WavesPrimaryActionBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource WavesPrimaryActionForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
        </Style>
        <convert:StepOKColorConverter x:Key="StepOKColorConverter" />
        <convert:StepOKVisiblityConverter x:Key="StepOKVisiblityConverter" />
        </ResourceDictionary>
    </Page.Resources>
    <Grid x:Name="backGrid" Margin="-1,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ProgressBar
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Background="Transparent"
            IsIndeterminate="{x:Bind ViewModel.ProcessAction, Mode=OneWay}" />
        <Border
            Grid.ColumnSpan="2"
            Margin="12,12,12,0"
            Padding="6"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{ThemeResource WavesCommandSurfaceBrush}"
            BorderBrush="{ThemeResource WavesCommandBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <ComboBox
                    Width="108"
                    Height="40"
                    Padding="10,5"
                    Background="{ThemeResource WavesSecondaryActionBrush}"
                    CornerRadius="6"
                    ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="m:ServerDisplay">
                            <TextBlock
                                FontFamily="{ThemeResource DefaultFont}"
                                FontSize="14"
                                Text="{x:Bind Display}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox
                    Width="132"
                    Height="40"
                    Padding="10,5"
                    Background="{ThemeResource WavesSecondaryActionBrush}"
                    CornerRadius="6"
                    ItemsSource="{x:Bind ViewModel.ChannelOptions, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedChannelOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.ChannelStatusText, Mode=OneWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="m:WavesChannelOption">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock
                                FontFamily="{ThemeResource DefaultFont}"
                                Text="{x:Bind Display}" />
                            <TextBlock
                                FontFamily="{ThemeResource DefaultFont}"
                                FontSize="11"
                                Opacity="0.7"
                                Text="{x:Bind Tag}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button
                Height="40"
                MinWidth="82"
                Padding="12,5"
                AutomationProperties.Name="切换到所选渠道"
                Background="{ThemeResource WavesSecondaryActionBrush}"
                Command="{x:Bind ViewModel.SwitchSelectedChannelCommand}"
                CornerRadius="6"
                Style="{ThemeResource TransparentButtonStyle}"
                ToolTipService.ToolTip="切换到所选渠道">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="12"
                        Glyph="&#xE8AB;" />
                    <TextBlock
                        FontFamily="{ThemeResource DefaultFont}"
                        FontSize="12"
                        Text="切换" />
                </StackPanel>
            </Button>
            <Button
                Height="40"
                Padding="12,5"
                AutomationProperties.Name="游戏目录"
                Background="{ThemeResource WavesSecondaryActionBrush}"
                CornerRadius="6"
                Style="{ThemeResource TransparentButtonStyle}"
                ToolTipService.ToolTip="定位游戏目录">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Command="{x:Bind ViewModel.SelectGameProgramCommand}"
                            Text="选择游戏目录">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="12"
                        Glyph="&#xE8B7;" />
                    <TextBlock
                        FontFamily="{ThemeResource DefaultFont}"
                        FontSize="12"
                        Text="游戏目录" />
                </StackPanel>
            </Button>
            <Button
                Height="40"
                Padding="12,5"
                AutomationProperties.Name="渠道备份"
                Background="{ThemeResource WavesSecondaryActionBrush}"
                CornerRadius="6"
                Style="{ThemeResource TransparentButtonStyle}"
                ToolTipService.ToolTip="备份与刷新渠道包">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Command="{x:Bind ViewModel.BackupCurrentChannelCommand}"
                            Text="备份当前渠道">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74E;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem
                            Command="{x:Bind ViewModel.RefreshSelectedChannelBackupCommand}"
                            Text="刷新所选渠道备份">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE895;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Command="{x:Bind ViewModel.OpenChannelBackupFolderCommand}"
                            Text="打开备份目录">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE838;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="12"
                        Glyph="&#xE74E;" />
                    <TextBlock
                        FontFamily="{ThemeResource DefaultFont}"
                        FontSize="12"
                        Text="备份" />
                </StackPanel>
            </Button>
            <Border
                Height="40"
                MaxWidth="260"
                Padding="12,0"
                Background="{ThemeResource WavesSecondaryActionBrush}"
                CornerRadius="6"
                ToolTipService.ToolTip="{x:Bind ViewModel.ChannelStatusText, Mode=OneWay}">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                    <Ellipse
                        Width="6"
                        Height="6"
                        Fill="{ThemeResource WavesStatusAccentBrush}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{ThemeResource DefaultFont}"
                        FontSize="12"
                        Text="{x:Bind ViewModel.ChannelStatusShortText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            </StackPanel>
        </Border>
        <!--  下载游戏  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.ColumnSpan="2"
            VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="col1" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromHorizontalOffset="-20" FromVerticalOffset="-20" />
                    <RepositionThemeTransition />
                </TransitionCollection>
            </Grid.Transitions>

            <Grid
                Grid.Row="1"
                Grid.Column="2"
                Margin="0,0,7,7"
                Padding="5"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                CornerRadius="5">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </Grid.ChildrenTransitions>
                <SystemBackdropElement
                    Grid.RowSpan="2"
                    CornerRadius="5"
                    Visibility="{x:Bind ViewModel.GameDownloadingBthVisibility, Mode=OneWay}">
                    <SystemBackdropElement.SystemBackdrop>
                        <DesktopAcrylicBackdrop />
                    </SystemBackdropElement.SystemBackdrop>
                </SystemBackdropElement>
                <Grid
                    Grid.Row="1"
                    Width="300"
                    Height="280"
                    HorizontalAlignment="Right"
                    CornerRadius="5"
                    Visibility="{x:Bind ViewModel.GameDownloadingBthVisibility, Mode=OneWay}">
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0" RowSpacing="5">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <lvc:CartesianChart
                            Margin="10,5,10,0"
                            AutoUpdateEnabled="True"
                            Background="Transparent"
                            SyncContext="{x:Bind ViewModel.Sync, Mode=OneWay}">

                            <lvc:CartesianChart.Series>
                                <lvc:SeriesCollection>
                                    <lvc:XamlLineSeries
                                        Fill="{ThemeResource DownloadSpeedPointSerialFillColor}"
                                        GeometryFill="{x:Null}"
                                        GeometryStroke="{x:Null}"
                                        ScalesYAt="1"
                                        SeriesName="下载"
                                        Stroke="{ThemeResource DownloadSpeedPointSerialStrokeColor}"
                                        Values="{x:Bind ViewModel.DownloadSpeedPoints, Mode=OneWay}"
                                        YToolTipLabelFormatter="{x:Bind ViewModel.DataLabelFormatter, Mode=OneWay}" />
                                    <lvc:XamlLineSeries
                                        Fill="{ThemeResource VerifySpeedPointSerialFillColor}"
                                        GeometryFill="{x:Null}"
                                        GeometryStroke="{x:Null}"
                                        ScalesYAt="0"
                                        SeriesName="校验"
                                        Stroke="{ThemeResource VerifySpeedPointSerialStrokeColor}"
                                        Values="{x:Bind ViewModel.VerifySpeedPoints, Mode=OneWay}"
                                        YToolTipLabelFormatter="{x:Bind ViewModel.DataLabelFormatter, Mode=OneWay}" />
                                    <lvc:XamlLineSeries
                                        Fill="{ThemeResource DecompressSpeedPointSerialFillColor}"
                                        GeometryFill="{x:Null}"
                                        GeometryStroke="{x:Null}"
                                        ScalesYAt="2"
                                        SeriesName="解压"
                                        Stroke="{ThemeResource DecompressSpeedPointSerialStrokeColor}"
                                        Values="{x:Bind ViewModel.DecompressSpeedPoints, Mode=OneWay}"
                                        YToolTipLabelFormatter="{x:Bind ViewModel.DataLabelFormatter, Mode=OneWay}" />
                                </lvc:SeriesCollection>
                            </lvc:CartesianChart.Series>
                            <lvc:CartesianChart.XAxes>
                                <lvc:AxesCollection>
                                    <lvc:XamlDateTimeAxis
                                        AnimationsSpeed="0"
                                        CustomSeparators="{x:Bind ViewModel.DownloadSpeedSeparators}"
                                        DateFormatter="{x:Bind ViewModel.LabelsFormatter}"
                                        Interval="0:0:1"
                                        SeparatorsPaint="{lvc:SolidColorPaint Color='64B4B4B4'}"
                                        TextSize="8" />
                                </lvc:AxesCollection>
                            </lvc:CartesianChart.XAxes>
                            <lvc:CartesianChart.YAxes>
                                <lvc:AxesCollection>
                                    <lvc:XamlAxis
                                        Padding="{lvc:Padding Value='0,0'}"
                                        LabelsPaint="{x:Null}"
                                        ShowSeparatorLines="False"
                                        TextSize="0" />
                                    <lvc:XamlAxis
                                        Padding="{lvc:Padding Value='0,0'}"
                                        LabelsPaint="{x:Null}"
                                        ShowSeparatorLines="False"
                                        TextSize="0" />
                                    <lvc:XamlAxis
                                        Padding="{lvc:Padding Value='0,0'}"
                                        LabelsPaint="{x:Null}"
                                        ShowSeparatorLines="False"
                                        TextSize="0" />
                                </lvc:AxesCollection>
                            </lvc:CartesianChart.YAxes>
                        </lvc:CartesianChart>
                        <TextBlock
                            Grid.Row="1"
                            Margin="20,0"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12">
                            <Run Text="任务步骤(" />
                            <Run Text="{x:Bind ViewModel.CurrentStep, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{x:Bind ViewModel.MaxStep, Mode=OneWay}" />
                            <Run Text=")" />
                        </TextBlock>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="20,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12">
                            <Run Text="{x:Bind ViewModel.CurrentStepText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock
                            Grid.Row="2"
                            Margin="20,0"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12"
                            Text="步骤进度" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="20,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12">
                            <Run Text="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />
                            <Run Text="%" />
                        </TextBlock>

                        <TextBlock
                            Grid.Row="3"
                            Margin="20,0"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12"
                            Text="活动文件" />
                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="20,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                Width="120"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource DefaultFont}"
                                FontSize="12"
                                Text="{x:Bind ViewModel.ActiveFile, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <Button
                                Margin="5,0,0,0"
                                Padding="3"
                                ToolTipService.ToolTip="显示更多文件">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    Glyph="&#xE712;" />
                                <Button.Flyout>
                                    <Flyout>
                                        <ScrollViewer>
                                            <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveFilesItems, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="item:DownloadActiveFileItem">
                                                        <Grid
                                                            Margin="5"
                                                            Padding="5"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                            CornerRadius="5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition />
                                                                <ColumnDefinition Width="auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{x:Bind FileName, Mode=OneWay}" />
                                                            <TextBlock Grid.Column="1" Margin="10,0,0,0">
                                                                <Run Text="{x:Bind Progress, Mode=OneWay}" />
                                                                <Run Text="%" />
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>

                                                </ItemsControl.ItemTemplate>
                                                <ItemsControl.ItemContainerTransitions>
                                                    <TransitionCollection>
                                                        <RepositionThemeTransition />
                                                    </TransitionCollection>
                                                </ItemsControl.ItemContainerTransitions>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                        <TextBlock
                            Grid.Row="4"
                            Margin="20,0"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12"
                            Text="数据容量" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="20,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource DefaultFont}"
                            FontSize="12">
                            <Run Text="{x:Bind ViewModel.CurrentByteText, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{x:Bind ViewModel.MaxByteText, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                    <Rectangle
                        x:Name="SeparatorLine"
                        Grid.Row="1"
                        Height="{ThemeResource NavigationViewItemSeparatorHeight}"
                        Fill="{ThemeResource NavigationViewItemSeparatorForeground}" />
                    <ProgressBar
                        Grid.Row="2"
                        MinHeight="39"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Maximum="{x:Bind ViewModel.MaxProgressValue, Mode=OneWay}"
                        Style="{ThemeResource FillHeightProgressBar}"
                        Value="{x:Bind ViewModel.CurrentProgressValue, Mode=OneWay}">
                        <ProgressBar.Foreground>
                            <SolidColorBrush Opacity="0.3" Color="{ThemeResource SystemAccentColor}" />
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    <StackPanel
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <Button
                            Width="40"
                            Height="40"
                            Margin="5,0,0,0"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Command="{x:Bind ViewModel.PauseDownloadTaskCommand}"
                            IsEnabled="{x:Bind ViewModel.PauseStartEnable, Mode=OneWay}"
                            Style="{ThemeResource TransparentButtonStyle}"
                            ToolTipService.ToolTip="暂停当前操作">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Glyph="{x:Bind ViewModel.PauseIcon, Mode=OneWay}" />
                        </Button>
                        <Button
                            Width="40"
                            Height="40"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Command="{x:Bind ViewModel.CancelDownloadTaskCommand}"
                            IsEnabled="{x:Bind ViewModel.PauseStartEnable, Mode=OneWay}"
                            Style="{ThemeResource TransparentButtonStyle}"
                            ToolTipService.ToolTip="取消当前操作">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Glyph="&#xE71A;" />
                        </Button>
                        <Button
                            Width="40"
                            Height="40"
                            Margin="0,-3,0,0"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="5"
                            Style="{ThemeResource TransparentButtonStyle}">
                            <FontIcon
                                FontFamily="Segoe UI Emoji"
                                FontSize="15"
                                Glyph="&#x1F914;" />
                            <Button.Flyout>
                                <Flyout ShouldConstrainToRootBounds="False">
                                    <Grid Width="400">
                                        <RichTextBlock
                                            FontFamily="{ThemeResource DefaultFont}"
                                            LineHeight="20"
                                            LineStackingStrategy="BlockLineHeight"
                                            TextWrapping="Wrap">
                                            <Paragraph>
                                                <Run
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    Text="使用注意事项" />

                                                <LineBreak />
                                                <LineBreak />
                                                <Run FontSize="12" Text="• 增量更新机制" />
                                                <LineBreak />
                                                <Run FontSize="12" Text="   - 剩余时间计算排除合并操作耗时，仅供参考" />

                                                <LineBreak />
                                                <LineBreak />

                                                <Run FontSize="12" Text="• 暂停与网络恢复" />
                                                <LineBreak />
                                                <Run FontSize="12" Text="   - 暂停期间断网将会退出下载状态" />

                                                <LineBreak />
                                                <LineBreak />

                                                <Run FontSize="12" Text="• 进度持久化" />
                                                <LineBreak />
                                                <Run FontSize="12" Text="   - 意外退出需重新校验，建议保持程序前台运行" />

                                                <LineBreak />
                                                <LineBreak />

                                                <Run FontSize="12" Text="• 硬件兼容性" />
                                                <LineBreak />
                                                <Run FontSize="12" Text="   - 机械硬盘校验效率约为SSD的1/3～1/5" />
                                            </Paragraph>
                                        </RichTextBlock>
                                    </Grid>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button
                            Width="40"
                            Height="40"
                            Margin="5,0,0,0"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="5"
                            Style="{ThemeResource TransparentButtonStyle}">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Glyph="&#xF8B0;" />
                            <Button.Flyout>
                                <Flyout>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Width="120"
                                            VerticalAlignment="Center"
                                            PlaceholderText="下载限速(mb/s)"
                                            Text="{x:Bind ViewModel.DownloadSpeedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTipService.ToolTip="默认为0，意为不限速" />
                                        <Button
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{x:Bind ViewModel.SetDownloadSpeedCommand}"
                                            Style="{ThemeResource AccentButtonStyle}">
                                            <FontIcon
                                                FontFamily="Segoe Fluent Icons"
                                                FontSize="15"
                                                Glyph="&#xE8FB;" />
                                        </Button>
                                    </Grid>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
