<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Haiyu.Pages.Dialogs.QRLoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Haiyu.Pages.Dialogs"
    xmlns:loginModel="using:Waves.Api.Models.QRLogin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Padding="0"
    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
    CornerRadius="8"
    mc:Ignorable="d">

    <Grid
        Width="460"
        Height="480"
        Padding="0"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <RepositionThemeTransition />
                <EntranceThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    FontFamily="{ThemeResource DefaultFont}"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="扫码登录" />
                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="选择包含游戏二维码的屏幕或窗口" />
            </StackPanel>

            <Button
                Grid.Column="2"
                Width="36"
                Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Command="{x:Bind ViewModel.CloseCommand}"
                CornerRadius="18"
                Style="{ThemeResource TransparentButtonStyle}"
                ToolTipService.ToolTip="关闭">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="14"
                    Glyph="&#xE894;" />
            </Button>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="18"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="捕获二维码" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.QRResult, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    MinWidth="150"
                    HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.InvokeCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="16"
                            Glyph="&#xE7F4;" />
                        <TextBlock Text="{x:Bind ViewModel.ScreenMessage, Mode=OneWay}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Border
                Padding="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Canvas.ZIndex="1"
                CornerRadius="8"
                Visibility="{x:Bind ViewModel.SessionVisibility, Mode=OneWay}">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Text="选择游戏角色" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="确认要登录的账号角色后继续。" />
                    </StackPanel>

                    <ListView
                        Grid.Row="1"
                        MaxHeight="210"
                        ItemsSource="{x:Bind ViewModel.Datums, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectDatum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="loginModel:Datum">
                                <Grid
                                    MinHeight="40"
                                    Padding="10,8"
                                    ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="16"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE77B;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind GetName}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Visibility="{x:Bind ViewModel.SelectWindowVisibility, Mode=OneWay}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="14">

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="等待选择扫码画面" />
                    <TextBlock
                        MaxWidth="300"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="保持游戏二维码可见，选择对应屏幕后会自动识别。"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>

            <Border
                Padding="24"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{x:Bind ViewModel.VerifyCodeVisibility, Mode=OneWay}">
                <StackPanel
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Spacing="14">
                    <TextBlock
                        FontSize="17"
                        FontWeight="SemiBold"
                        Text="安全校验" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="输入手机收到的验证码后继续登录。"
                        TextWrapping="WrapWholeWords" />
                    <TextBox
                        Header="安全验证码"
                        PlaceholderText="输入手机收到的验证码"
                        Text="{x:Bind ViewModel.VerifyCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>


            <Button
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.LoginCommand}"
                Visibility="{x:Bind ViewModel.LoginBthVisibility, Mode=OneWay}">
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Glyph="&#xE73E;" />
                    <TextBlock Text="确认登录" />
                </StackPanel>
            </Button>

            <Border
                Grid.Row="1"
                Padding="12,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE946;" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.TipMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentDialog>
