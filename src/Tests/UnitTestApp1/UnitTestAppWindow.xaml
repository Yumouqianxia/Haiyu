<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UnitTestApp1.UnitTestAppWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UnitTestApp1"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:Haiyu.Controls.Controls"
    Title="UnitTestApp1"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <ui:GameSelectionCard
            Width="400"
            Height="200"
            Padding="10"
            Background="LightGreen"
            BorderBrush="LightGreen"
            BorderThickness="5"
            CornerRadius="10">
            <ui:GameSelectionCard.CardContent>
                <Grid
                    Grid.Row="1"
                    Margin="8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" Text="青山绿水" />
                    <TextBlock
                        Grid.Row="1"
                        FontSize="12"
                        Foreground="{ThemeResource SystemColorGrayTextBrush}"
                        Text="青山横北郭，白水绕东城" />
                </Grid>
            </ui:GameSelectionCard.CardContent>
        </ui:GameSelectionCard>
    </Grid>
</Window>
